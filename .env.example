# Chave SMTP / transaccional Brevo — NUNCA use prefixo NEXT_PUBLIC_ (expõe a chave no browser).
BREVO_API_KEY=

# Remetente verificado na conta Brevo (Domínios / SMTP & API).
BREVO_SENDER_EMAIL=no-reply@seudominioverificado.pt

# OpenRouter (chat Radar) — apenas no servidor. Preferido: OPEN_ROUTER_API_KEY sem NEXT_PUBLIC_,
# assim a chave não entra acidentalmente no bundle do navegador. Migrar valores antigos com NEXT_PUBLIC_ se existirem.
OPEN_ROUTER_API_KEY=

